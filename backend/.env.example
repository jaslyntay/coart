# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this backend.
# In dev: your local Vercel preview. In prod: coart.vercel.app
CORS_ORIGINS=http://localhost:3000,https://coart.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Service role bypasses RLS — used for server-side operations only.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic ─────────────────────────────────────────────────────────
# Get this from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model to use for drafting + chat.
# claude-sonnet-4-6 is the good balance of quality and cost.
# Switch to claude-haiku-4-5-20251001 if you want it cheaper/faster.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Email (optional, for external grant submissions) ─────────────────
# Sign up at resend.com to get a key.
# If empty, external submissions fall back to manual_copy only.
RESEND_API_KEY=
RESEND_FROM_EMAIL=applications@coart.com
